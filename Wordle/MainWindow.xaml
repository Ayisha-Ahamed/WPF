<Window x:Class="Wordle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wordle" 
        mc:Ignorable="d" KeyDown="Key_OnPressed" MinWidth="300" SizeToContent="WidthAndHeight">
   <Window.Resources>
      <Style x:Key="LbInput" TargetType="Label">
         <Setter Property="Foreground" Value="Black"/>
         <Setter Property="Background" Value="White"/>
         <Setter Property="Padding" Value="10"/>
         <Setter Property="FontWeight" Value="SemiBold"/>
         <Setter Property="HorizontalContentAlignment" Value="Center"/>
         <Setter Property="VerticalContentAlignment" Value="Center"/>
         <Setter Property="FontSize" Value="18"/>
         <Setter Property="Height" Value="50"/>
         <Setter Property="Margin" Value="5"/>
         <Setter Property="Width" Value="50"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="BorderBrush" Value="Black"/>
      </Style>

      <Style x:Key="LetterFound" TargetType="Label" BasedOn="{StaticResource LbInput}">
         <Setter Property="Background" Value="ForestGreen"/>
      </Style>

      <Style x:Key="Letter" TargetType="Button">
         <Setter Property="Foreground" Value="Black"/>
         <Setter Property="Background" Value="White"/>
         <Setter Property="BorderBrush" Value="DimGray"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="Padding" Value="10"/>
         <Setter Property="FontWeight" Value="SemiBold"/>
         <Setter Property="FontSize" Value="18"/>
         <Setter Property="Height" Value="50"/>
         <Setter Property="Margin" Value="10"/>
         <Setter Property="Width" Value="40"/>
         <Setter Property="HorizontalContentAlignment" Value="Center"/>
         <Setter Property="VerticalContentAlignment" Value="Center"/>
         <Setter Property="Content" Value="X"/>
      </Style>
   </Window.Resources>
   <Grid Margin="20">
      <Grid.RowDefinitions>
         <RowDefinition MinHeight="30"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition MinHeight="30"/>
      </Grid.RowDefinitions>
      <UniformGrid Name="gInput" Margin="100,10" Grid.Row="1" Rows="6" Columns="5">
         <UniformGrid.Resources>
            <Style TargetType="Label" BasedOn="{StaticResource LbInput}"/>
         </UniformGrid.Resources>
      </UniformGrid>
      <UniformGrid Name="gAlphabets" Grid.Row="2" Rows ="3" Columns="10" ButtonBase.Click="Button_OnClicked">
         <UniformGrid.Resources>
            <Style TargetType="Button" BasedOn="{StaticResource Letter}"/>
         </UniformGrid.Resources>
      </UniformGrid>
      <Viewbox Grid.Row="3" Height="50" Margin="10">
         <TextBlock Name="TbResult" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
      </Viewbox>

   </Grid>
</Window>